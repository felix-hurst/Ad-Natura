# Remove the line below if you want to inherit .editorconfig settings from higher directories
root = true

# C# files
[*.cs]

#### Core EditorConfig Options ####
indent_size = 4
indent_style = space
tab_width = 4
end_of_line = crlf

#### C# Formatting Rules (Allman Style) ####

# Allman style means braces go on a NEW line
csharp_new_line_before_open_brace = all
csharp_new_line_before_catch = true
csharp_new_line_before_else = true
csharp_new_line_before_finally = true
csharp_new_line_before_members_in_anonymous_types = true
csharp_new_line_before_members_in_object_initializers = true

# Indentation
csharp_indent_block_contents = true
csharp_indent_braces = false
csharp_indent_case_contents = true
csharp_indent_switch_labels = true

#### Naming Styles ####

#Classes, Methods (Functions), and Structs must be PascalCase
dotnet_naming_rule.types_and_methods_should_be_pascal_case.severity = warning
dotnet_naming_rule.types_and_methods_should_be_pascal_case.symbols = types_and_methods
dotnet_naming_rule.types_and_methods_should_be_pascal_case.style = pascal_case_style

dotnet_naming_symbols.types_and_methods.applicable_kinds = class, method, struct, enum, property
dotnet_naming_symbols.types_and_methods.applicable_accessibilities = *

#Variables (Fields, Locals, Parameters) must be camelCase
dotnet_naming_rule.variables_should_be_camel_case.severity = warning
dotnet_naming_rule.variables_should_be_camel_case.symbols = variables
dotnet_naming_rule.variables_should_be_camel_case.style = camel_case_style

dotnet_naming_symbols.variables.applicable_kinds = variable, local, parameter, field
dotnet_naming_symbols.variables.applicable_accessibilities = *

# Define the styles
dotnet_naming_style.pascal_case_style.capitalization = pascal_case
dotnet_naming_style.camel_case_style.capitalization = camel_case