    - target: {fileID: 3435467237574143893, guid: b6ff7e9fa6be6224db075a4f94c206ec, type: 3}
      propertyPath: bobSpeed
      value: 2
      objectReference: {fileID: 0}
    - target: {fileID: 3435467237574143893, guid: b6ff7e9fa6be6224db075a4f94c206ec, type: 3}
      propertyPath: journalTitle
      value: 'Mission Log #1: Arrival'
      objectReference: {fileID: 0}
    - target: {fileID: 3435467237574143893, guid: b6ff7e9fa6be6224db075a4f94c206ec, type: 3}
      propertyPath: journalFullText
      value: 'There are the roots of dead trees in my way. Perhaps if I get them
        wet, the slime mold may be able to decompose them and break them down, helping
        me get through. I could use the water shooter tool I was supplied with, or
        if there are any other water sources in the area, I may be able to use those
        as well.



        If there is any brittle stone in my way, I could use
        my impact rounds to break them apart. They won''t work on anything sturdier,
        though.



        I was also given a wind fan tool, but I''m not sure yet
        what it might be useful for.'
      objectReference: {fileID: 0}
    - target: {fileID: 3435467237574143893, guid: b6ff7e9fa6be6224db075a4f94c206ec, type: 3}
      propertyPath: playerLayer.m_Bits
      value: 0
      objectReference: {fileID: 0}
