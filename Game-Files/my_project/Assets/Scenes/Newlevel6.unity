    - target: {fileID: 3406898395983688105, guid: b6ff7e9fa6be6224db075a4f94c206ec, type: 3}
      propertyPath: m_Name
      value: 'Mission Log #4: Progress'
      objectReference: {fileID: 0}
    - target: {fileID: 3435467237574143893, guid: b6ff7e9fa6be6224db075a4f94c206ec, type: 3}
      propertyPath: bobSpeed
      value: 2
      objectReference: {fileID: 0}
    - target: {fileID: 3435467237574143893, guid: b6ff7e9fa6be6224db075a4f94c206ec, type: 3}
      propertyPath: journalTitle
      value: 'Mission Log #4: Progress'
      objectReference: {fileID: 0}
    - target: {fileID: 3435467237574143893, guid: b6ff7e9fa6be6224db075a4f94c206ec, type: 3}
      propertyPath: journalFullText
      value: 'I can''t tell if this is working or not. The calamity, it''s everywhere
        now. Water doesn''t wash it away. I suppose the least I can do is continue
        trying to clear out all of these pollution sources and decaying matter in
        my immediate location. Then, we will at least have a clear space to rebuild
        after all this is over. If the pollution doesn''t just regrow in this place
        again, that is.



        The slime mold certainly doesn''t like the pollution,
        either...'
      objectReference: {fileID: 0}
    - target: {fileID: 6485533160007763511, guid: b6ff7e9fa6be6224db075a4f94c206ec, type: 3}
